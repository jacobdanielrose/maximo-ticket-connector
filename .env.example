# Maximo Connector - Build and Push Configuration
# Copy this file to .env and fill in your values
# Then run: source .env && ./build-and-push.sh

# ============================================================================
# REQUIRED: Container Registry Configuration
# ============================================================================

# Registry URL - Examples:
#   Docker Hub:        docker.io
#   GitHub Container:  ghcr.io
#   Quay.io:          quay.io
#   Google GCR:       gcr.io
#   AWS ECR:          <account-id>.dkr.ecr.<region>.amazonaws.com
export REGISTRY_URL=docker.io

# Registry credentials
export REGISTRY_USERNAME=your-username
export REGISTRY_PASSWORD=your-password-or-token

# Image name (without registry URL)
# Examples:
#   Docker Hub:        username/maximo-connector
#   GitHub Container:  username/maximo-connector
#   Quay.io:          organization/maximo-connector
export IMAGE_NAME=your-org/maximo-connector

# Image tag (version)
export IMAGE_TAG=latest

# ============================================================================
# OPTIONAL: Advanced Configuration
# ============================================================================

# Maven Docker image to use for building
# Default: maven:3.9-eclipse-temurin-21
# export MAVEN_IMAGE=maven:3.9-eclipse-temurin-21

# Additional Docker build arguments
# Example: export BUILD_ARGS="--no-cache --build-arg HTTP_PROXY=http://proxy:8080"
# export BUILD_ARGS=

# ============================================================================
# Registry-Specific Examples
# ============================================================================

# --- Docker Hub ---
# export REGISTRY_URL=docker.io
# export REGISTRY_USERNAME=myusername
# export REGISTRY_PASSWORD=dckr_pat_xxxxxxxxxxxxxxxxxxxxx
# export IMAGE_NAME=myusername/maximo-connector
# export IMAGE_TAG=1.0.0

# --- GitHub Container Registry (ghcr.io) ---
# export REGISTRY_URL=ghcr.io
# export REGISTRY_USERNAME=myusername
# export REGISTRY_PASSWORD=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# export IMAGE_NAME=myusername/maximo-connector
# export IMAGE_TAG=1.0.0

# --- Quay.io ---
# export REGISTRY_URL=quay.io
# export REGISTRY_USERNAME=myorg+robot
# export REGISTRY_PASSWORD=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# export IMAGE_NAME=myorg/maximo-connector
# export IMAGE_TAG=1.0.0

# --- Google Container Registry (GCR) ---
# export REGISTRY_URL=gcr.io
# export REGISTRY_USERNAME=_json_key
# export REGISTRY_PASSWORD=<contents of service account JSON key>
# export IMAGE_NAME=my-project/maximo-connector
# export IMAGE_TAG=1.0.0

# --- AWS Elastic Container Registry (ECR) ---
# Note: For ECR, you need to get a login token first:
# aws ecr get-login-password --region us-east-1
# export REGISTRY_URL=123456789012.dkr.ecr.us-east-1.amazonaws.com
# export REGISTRY_USERNAME=AWS
# export REGISTRY_PASSWORD=<token from aws ecr get-login-password>
# export IMAGE_NAME=maximo-connector
# export IMAGE_TAG=1.0.0